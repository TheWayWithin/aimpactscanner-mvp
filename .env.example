# AImpactScanner Environment Configuration
# Copy this file to .env.local and fill in your actual values

# Supabase Configuration
VITE_SUPABASE_URL=your_supabase_url_here
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Google Tag Manager Configuration
VITE_GTM_CONTAINER_ID=GTM-WCQGG5N6

# Google Analytics 4 Configuration (configured via GTM)
VITE_GA4_MEASUREMENT_ID=G-EJ5M874QBZ

# Environment Settings
VITE_ENVIRONMENT=development
VITE_DEBUG_ANALYTICS=true

# Stripe Configuration
VITE_STRIPE_PUBLISHABLE_KEY=your_stripe_publishable_key
STRIPE_SECRET_KEY=your_stripe_secret_key

# GDPR & Privacy
VITE_PRIVACY_POLICY_URL=https://aimpactscanner.com/privacy
VITE_TERMS_OF_SERVICE_URL=https://aimpactscanner.com/terms

# Production URLs
VITE_SITE_URL=https://aimpactscanner.com
VITE_API_URL=https://aimpactscanner.com/api