{
  "name": "aimpactscanner-mvp",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "node scripts/generate-sitemap.js && vite build && ./scripts/fix-production-build.sh && node scripts/verify-infrastructure.js",
    "build:raw": "vite build",
    "lint": "eslint . --ext js,jsx --report-unused-disable-directives --max-warnings 0",
    "preview": "vite preview",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "vitest run",
    "test:watch": "vitest --watch",
    "test:coverage": "vitest run --coverage",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "test:e2e": "vitest run tests/e2e",
    "test:performance": "vitest run tests/performance",
    "test:factors": "vitest run tests/unit/factors.test.js",
    "test:db": "vitest run tests/integration/analysis-flow.test.js -t \"Database Operations\"",
    "test:progress": "vitest run tests/integration/analysis-flow.test.js -t \"Real-time Progress\"",
    "test:edge": "vitest run tests/integration/analysis-flow.test.js -t \"Edge Function\"",
    "test:ci": "vitest run --reporter=json --outputFile=test-results/ci-results.json",
    "test:debug": "vitest --inspect-brk",
    "test:setup": "node tests/setup/database-setup.js",
    "test:summary": "node tests/test-summary.js",
    "test:playwright": "npx playwright test",
    "test:playwright:ui": "npx playwright test --ui",
    "test:playwright:debug": "npx playwright test --debug",
    "test:playwright:report": "npx playwright show-report",
    "test:revenue": "npx playwright test tests/playwright/revenue-activation.spec.js",
    "test:revenue:ui": "npx playwright test tests/playwright/revenue-activation.spec.js --ui",
    "test:revenue:debug": "npx playwright test tests/playwright/revenue-activation.spec.js --debug",
    "test:revenue:report": "npx playwright test tests/playwright/revenue-activation.spec.js && npx playwright show-report",
    "test:phase2": "npx playwright test tests/phase2-auth-pricing.spec.js",
    "test:phase2:ui": "npx playwright test tests/phase2-auth-pricing.spec.js --ui",
    "test:phase2:debug": "npx playwright test tests/phase2-auth-pricing.spec.js --debug",
    "test:phase2:report": "npx playwright test tests/phase2-auth-pricing.spec.js && npx playwright show-report",
    "test:phase2:auth": "npx playwright test tests/phase2-auth-pricing.spec.js --grep \"Authentication System\"",
    "test:phase2:pricing": "npx playwright test tests/phase2-auth-pricing.spec.js --grep \"Pricing Display\"",
    "test:phase2:registration": "npx playwright test tests/phase2-auth-pricing.spec.js --grep \"Registration Flow\"",
    "test:phase2:mobile": "npx playwright test tests/phase2-auth-pricing.spec.js --project=\"Mobile Chrome\"",
    "test:phase2:performance": "npx playwright test tests/phase2-auth-pricing.spec.js --grep \"Performance Tests\"",
    "test:temp-email": "npx playwright test tests/e2e/user-journey-with-temp-email.spec.js",
    "test:temp-email:ui": "npx playwright test tests/e2e/user-journey-with-temp-email.spec.js --ui",
    "test:temp-email:debug": "npx playwright test tests/e2e/user-journey-with-temp-email.spec.js --debug",
    "test:usage-tracking": "npx playwright test tests/e2e/usage-tracking-flow.spec.js",
    "test:error-handling": "npx playwright test tests/e2e/error-handling-edge-cases.spec.js",
    "test:e2e:all": "npx playwright test tests/e2e/",
    "test:e2e:ci": "npx playwright test tests/e2e/ --reporter=json --output-dir=test-results/e2e",
    "test:validate-phase2": "node tests/validate-phase2-setup.js",
    "verify:migration": "node scripts/verify-coffee-tier-migration.js",
    "verify:steps": "node scripts/verify-step-by-step.js",
    "setup:coffee-tier": "node scripts/verify-coffee-tier-migration.js",
    "deploy:functions": "npx supabase functions deploy analyze-page && npx supabase functions deploy create-checkout-session && npx supabase functions deploy stripe-webhook",
    "deploy:production": "npm run build && npm run deploy:functions",
    "coffee:status": "node scripts/verify-step-by-step.js && echo '\n\ud83c\udfaf Coffee Tier Status: Ready for Production Revenue Generation!'",
    "coffee:test": "node scripts/test-coffee-tier-stripe.js",
    "test:webhook": "./tests/webhook/run-tests.sh",
    "test:webhook:cancellation": "npx vitest run --config=vitest.webhook-minimal.config.js",
    "coffee:setup-guide": "cat scripts/setup-stripe-test-mode.md",
    "test:tier": "node tests/run-tier-tests.js",
    "test:tier:all": "node tests/run-tier-tests.js all",
    "test:tier:free": "node tests/run-tier-tests.js tier FREE",
    "test:tier:coffee": "node tests/run-tier-tests.js tier COFFEE",
    "test:tier:growth": "node tests/run-tier-tests.js tier GROWTH",
    "test:tier:scale": "node tests/run-tier-tests.js tier SCALE",
    "test:tier:cross-browser": "node tests/run-tier-tests.js cross-browser",
    "test:tier:performance": "node tests/run-tier-tests.js performance",
    "test:tier:quick": "node tests/run-tier-tests.js quick",
    "test:tier:debug": "node tests/run-tier-tests.js debug",
    "test:tier:debug:free": "node tests/run-tier-tests.js debug FREE",
    "test:tier:debug:coffee": "node tests/run-tier-tests.js debug COFFEE",
    "test:tier:ui": "npx playwright test tests/tiers/tier-signup-flows.spec.js --ui",
    "test:tier:report": "npx playwright show-report test-results/tier-tests/playwright-report",
    "analyze:performance": "node scripts/performance-analysis.js",
    "analyze:bundle": "npm run build && npx vite bundle-analyzer",
    "optimize:check": "npm run analyze:performance && npm run build --silent",
    "test:uat": "node tests/uat/run-uat.js",
    "test:uat:setup": "node tests/uat/setup-uat.js",
    "test:uat:cleanup": "node tests/uat/setup-uat.js --cleanup",
    "test:uat:all": "node tests/uat/run-uat.js --category all",
    "test:uat:anonymous": "node tests/uat/run-uat.js --category anonymous",
    "test:uat:free": "node tests/uat/run-uat.js --category free",
    "test:uat:paid": "node tests/uat/run-uat.js --category paid",
    "test:uat:auth": "node tests/uat/run-uat.js --category auth",
    "test:uat:analysis": "node tests/uat/run-uat.js --category analysis",
    "test:uat:payment": "node tests/uat/run-uat.js --category payment",
    "test:uat:edge": "node tests/uat/run-uat.js --category edge",
    "test:uat:browser": "node tests/uat/run-uat.js --category browser",
    "test:uat:mobile": "node tests/uat/run-uat.js --category mobile",
    "test:uat:debug": "node tests/uat/run-uat.js --debug --headed",
    "test:uat:report": "npx playwright show-report test-results/uat",
    "test:uat:ci": "node tests/uat/setup-uat.js && node tests/uat/run-uat.js --category all",
    "uat": "npm run test:uat:setup && npm run test:uat",
    "test:api:setup": "node tests/api/setup-scale-user.js",
    "test:api": "node tests/api/api-keys-test.js",
    "test:api:staging": "API_TEST_STAGING_URL=https://aimpactscanner-backend-production.up.railway.app node tests/api/api-keys-test.js",
    "test:pure": "vitest run --config=vitest.pure.config.js"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.51.0",
    "bcryptjs": "^3.0.2",
    "html2canvas": "^1.4.1",
    "jspdf": "^3.0.1",
    "lucide-react": "^0.575.0",
    "prop-types": "^15.8.1",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.29.0",
    "@playwright/test": "^1.54.2",
    "@tailwindcss/postcss": "^4.1.11",
    "@testing-library/jest-dom": "^6.8.0",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.3.0",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react-swc": "^3.10.2",
    "@vitest/coverage-v8": "^2.0.5",
    "@vitest/ui": "^2.0.5",
    "autoprefixer": "^10.4.21",
    "chrome-launcher": "^1.2.1",
    "dotenv": "^16.4.5",
    "eslint": "^9.29.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "globals": "^16.2.0",
    "jsdom": "^25.0.1",
    "lighthouse": "^12.8.2",
    "playwright": "^1.55.0",
    "playwright-lighthouse": "^4.0.0",
    "postcss": "^8.5.6",
    "rollup-plugin-visualizer": "^6.0.3",
    "tailwindcss": "^4.1.10",
    "terser": "^5.44.0",
    "vite": "^7.0.0",
    "vitest": "^2.0.5"
  }
}
