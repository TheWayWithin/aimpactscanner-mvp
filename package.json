{
  "name": "aimpactscanner-mvp",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint . --ext js,jsx --report-unused-disable-directives --max-warnings 0",
    "preview": "vite preview",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "vitest run",
    "test:watch": "vitest --watch",
    "test:coverage": "vitest run --coverage",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "test:e2e": "vitest run tests/e2e",
    "test:performance": "vitest run tests/performance",
    "test:factors": "vitest run tests/unit/factors.test.js",
    "test:db": "vitest run tests/integration/analysis-flow.test.js -t \"Database Operations\"",
    "test:progress": "vitest run tests/integration/analysis-flow.test.js -t \"Real-time Progress\"",
    "test:edge": "vitest run tests/integration/analysis-flow.test.js -t \"Edge Function\"",
    "test:ci": "vitest run --reporter=json --outputFile=test-results/ci-results.json",
    "test:debug": "vitest --inspect-brk",
    "test:setup": "node tests/setup/database-setup.js",
    "test:summary": "node tests/test-summary.js",
    "test:playwright": "npx playwright test",
    "test:playwright:ui": "npx playwright test --ui",
    "test:playwright:debug": "npx playwright test --debug",
    "test:playwright:report": "npx playwright show-report",
    "test:revenue": "npx playwright test tests/playwright/revenue-activation.spec.js",
    "test:revenue:ui": "npx playwright test tests/playwright/revenue-activation.spec.js --ui",
    "test:revenue:debug": "npx playwright test tests/playwright/revenue-activation.spec.js --debug",
    "test:revenue:report": "npx playwright test tests/playwright/revenue-activation.spec.js && npx playwright show-report",
    "test:phase2": "npx playwright test tests/phase2-auth-pricing.spec.js",
    "test:phase2:ui": "npx playwright test tests/phase2-auth-pricing.spec.js --ui",
    "test:phase2:debug": "npx playwright test tests/phase2-auth-pricing.spec.js --debug",
    "test:phase2:report": "npx playwright test tests/phase2-auth-pricing.spec.js && npx playwright show-report",
    "test:phase2:auth": "npx playwright test tests/phase2-auth-pricing.spec.js --grep \"Authentication System\"",
    "test:phase2:pricing": "npx playwright test tests/phase2-auth-pricing.spec.js --grep \"Pricing Display\"",
    "test:phase2:registration": "npx playwright test tests/phase2-auth-pricing.spec.js --grep \"Registration Flow\"",
    "test:phase2:mobile": "npx playwright test tests/phase2-auth-pricing.spec.js --project=\"Mobile Chrome\"",
    "test:phase2:performance": "npx playwright test tests/phase2-auth-pricing.spec.js --grep \"Performance Tests\"",
    "test:temp-email": "npx playwright test tests/e2e/user-journey-with-temp-email.spec.js",
    "test:temp-email:ui": "npx playwright test tests/e2e/user-journey-with-temp-email.spec.js --ui",
    "test:temp-email:debug": "npx playwright test tests/e2e/user-journey-with-temp-email.spec.js --debug",
    "test:usage-tracking": "npx playwright test tests/e2e/usage-tracking-flow.spec.js",
    "test:error-handling": "npx playwright test tests/e2e/error-handling-edge-cases.spec.js",
    "test:e2e:all": "npx playwright test tests/e2e/",
    "test:e2e:ci": "npx playwright test tests/e2e/ --reporter=json --output-dir=test-results/e2e",
    "test:validate-phase2": "node tests/validate-phase2-setup.js",
    "verify:migration": "node scripts/verify-coffee-tier-migration.js",
    "verify:steps": "node scripts/verify-step-by-step.js",
    "setup:coffee-tier": "node scripts/verify-coffee-tier-migration.js",
    "deploy:functions": "npx supabase functions deploy analyze-page && npx supabase functions deploy create-checkout-session && npx supabase functions deploy stripe-webhook",
    "deploy:production": "npm run build && npm run deploy:functions",
    "coffee:status": "node scripts/verify-step-by-step.js && echo '\n🎯 Coffee Tier Status: Ready for Production Revenue Generation!'",
    "coffee:test": "node scripts/test-coffee-tier-stripe.js",
    "coffee:setup-guide": "cat scripts/setup-stripe-test-mode.md"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.51.0",
    "node-fetch": "^3.3.2",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.29.0",
    "@playwright/test": "^1.54.2",
    "@tailwindcss/postcss": "^4.1.11",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react-swc": "^3.10.2",
    "@vitest/coverage-v8": "^2.0.5",
    "@vitest/ui": "^2.0.5",
    "autoprefixer": "^10.4.21",
    "dotenv": "^16.4.5",
    "eslint": "^9.29.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "globals": "^16.2.0",
    "jsdom": "^25.0.1",
    "playwright": "^1.54.1",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.1.10",
    "vite": "^7.0.0",
    "vitest": "^2.0.5"
  }
}
