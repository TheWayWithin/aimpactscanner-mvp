# Node Environment
NODE_ENV=development
PORT=3001

# Supabase Configuration
# CRITICAL: Use STAGING database for local dev and deploy previews
# Production values are set via Railway environment variables
# Staging: isgzvwpjokcmtizstwru.supabase.co
# Production: pdmtvkcxnqysujnpcnyh.supabase.co (NEVER use for local dev)
SUPABASE_URL=https://isgzvwpjokcmtizstwru.supabase.co
SUPABASE_ANON_KEY=your-staging-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-staging-service-role-key-here

# CORS Configuration
# Comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# LLMtxtMastery API (for generate-llmstxt endpoint)
LLMTXT_MASTERY_API_KEY=your-llmtxt-api-key-here

# Puppeteer Configuration (Phase 4)
# PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium-browser

# Logging
LOG_LEVEL=info

# SECURITY NOTES:
# - NEVER commit .env file to git
# - Use .env.local for local development
# - Use Railway environment variables for production
# - Service role key grants admin access - protect it carefully
# - Staging DB (isgzvwpjokcmtizstwru) is SAFE for testing
# - Production DB (pdmtvkcxnqysujnpcnyh) is NEVER for testing
